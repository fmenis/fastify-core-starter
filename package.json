{
  "name": "fastify-core-starter",
  "version": "0.4.0",
  "description": "Base Fastify setup for Node.js applications",
  "keywords": [
    "fastify",
    "boilerplate"
  ],
  "license": "ISC",
  "author": "filippomeniswork@gmail.com",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "prod:http": "APP_MODE=http node --env-file .env dist/main.js",
    "prod:worker": "APP_MODE=worker node --env-file .env dist/main.js",
    "dev:http": "APP_MODE=http tsx watch --env-file .env --inspect src/main.ts",
    "dev:worker": "APP_MODE=worker tsx --env-file .env src/main.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:integration": "docker compose -f tests/docker-compose.test.yml up -d --wait && vitest run --config tests/vitest.integration.config.ts; EC=$?; docker compose -f tests/docker-compose.test.yml down; exit $EC",
    "test:integration:watch": "vitest --config tests/vitest.integration.config.ts",
    "lint:check": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "initStack": "cd ./local-stack && docker compose up -d",
    "shutdown-stack": "cd ./local-stack && docker compose down",
    "rebuild-stack": "./local-stack/rebuild-db.sh",
    "prepare": "husky",
    "kysely:codegen": "kysely-codegen --dialect postgres --exclude-pattern migrations --out-file ./src/generated/kysely/types.ts",
    "db:migrate": "tsx --env-file .env ./src/scripts/applyMigrations.ts",
    "job:delete-inactive-profiles": "tsx --env-file .env src/scripts/deleteInactiveProfiles.ts"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@bull-board/api": "^7.1.5",
    "@bull-board/fastify": "^7.1.5",
    "@fastify/cors": "^11.1.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@sentry/node": "^10.27.0",
    "ajv-formats": "^3.0.1",
    "bullmq": "^5.64.1",
    "close-with-grace": "^2.3.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "kysely": "^0.28.10",
    "pg": "^8.16.3",
    "postgrator": "^8.0.0",
    "rimraf": "^6.1.0",
    "typebox": "^1.0.60"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^10.2.0",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fastify-tsconfig": "^3.0.0",
    "husky": "^9.1.7",
    "kysely-codegen": "^0.19.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ]
  }
}
